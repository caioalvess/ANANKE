# ANANKE Crypto Tracker — Environment Configuration
# Copy to .env and customize as needed.

# Enabled exchanges (comma-separated)
# ANANKE_ENABLED_EXCHANGES=binance,bybit,okx,kraken,kucoin

# Binance
# ANANKE_BINANCE_REST_URL=https://api.binance.com
# ANANKE_BINANCE_WS_URL=wss://stream.binance.com:9443/ws/!ticker@arr
# ANANKE_BINANCE_REST_TIMEOUT=15

# Bybit
# ANANKE_BYBIT_REST_URL=https://api.bybit.com
# ANANKE_BYBIT_POLL_INTERVAL=2.0
# ANANKE_BYBIT_REST_TIMEOUT=15

# OKX
# ANANKE_OKX_REST_URL=https://www.okx.com
# ANANKE_OKX_POLL_INTERVAL=2.0
# ANANKE_OKX_REST_TIMEOUT=15

# Kraken
# ANANKE_KRAKEN_REST_URL=https://api.kraken.com
# ANANKE_KRAKEN_POLL_INTERVAL=2.0
# ANANKE_KRAKEN_REST_TIMEOUT=15

# KuCoin
# ANANKE_KUCOIN_REST_URL=https://api.kucoin.com
# ANANKE_KUCOIN_POLL_INTERVAL=2.0
# ANANKE_KUCOIN_REST_TIMEOUT=15

# Web Server
# ANANKE_WEB_HOST=0.0.0.0
# ANANKE_WEB_PORT=8080
# ANANKE_BROADCAST_INTERVAL=1.0

# Terminal Display
# ANANKE_PAGE_SIZE=40
# ANANKE_REFRESH_MS=500

# Logging
# ANANKE_LOG_LEVEL=WARNING
# ANANKE_LOG_FILE=ananke.log
